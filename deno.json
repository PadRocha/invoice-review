{
  "nodeModulesDir": "auto",
  "imports": {
    "@cli": "./cli/index.ts",
    "@cli/": "./cli/",
    "@comparison": "./core/comparison/index.ts",
    "@comparison/": "./core/comparison/",
    "@controllers": "./controllers/index.ts",
    "@controllers/": "./controllers/",
    "@errors": "./errors/index.ts",
    "@errors/": "./errors/",
    "@interfaces/": "./interfaces/",
    "@models": "./models/index.ts",
    "@models/": "./models/",
    "@services/": "./services/",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/fs": "jsr:@std/fs@^1.0.23",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@spreadsheet": "./core/spreadsheet/index.ts",
    "@spreadsheet/": "./core/spreadsheet/",
    "@utils/": "./utils/",
    "xlsx": "npm:xlsx@^0.18.5"
  },
  "tasks": {
    "help": "deno run --allow-read --allow-write main.ts --help",
    "review": "deno run --allow-read --allow-write main.ts",
    "dev": "deno run --watch --allow-read --allow-write main.ts",
    "test": "deno test --allow-read --allow-write",
    "build:linux": "deno compile --target x86_64-unknown-linux-gnu --allow-read --allow-write -o dist/invrev main.ts",
    "build:windows": "deno compile --target x86_64-pc-windows-msvc --allow-read --allow-write -o dist/invrev.exe main.ts"
  },
  "fmt": {
    "lineWidth": 80,
    "indentWidth": 2,
    "useTabs": false,
    "singleQuote": false,
    "semiColons": true
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ]
    }
  }
}
